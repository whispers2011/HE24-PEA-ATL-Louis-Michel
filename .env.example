# Vorlage für die lokale .env – Werte anpassen und als .env speichern.
# Die echte .env wird nie committet (siehe .gitignore).

# Datenbank-Verbindung (SQLAlchemy-URL)
DATABASE_URL=sqlite:///./app.db

# Basis-URL für die Ausgabe der Kurzlinks
BASE_URL=http://localhost:8000

# Länge der generierten Kurzcodes
CODE_LENGTH=6

# Geheimer Schlüssel für die JWT-Signatur (HS256) – in Produktion zwingend ändern
SECRET_KEY=change-me-use-a-long-random-secret-key

# Gültigkeitsdauer eines Access-Tokens in Minuten
ACCESS_TOKEN_EXPIRE_MINUTES=60
